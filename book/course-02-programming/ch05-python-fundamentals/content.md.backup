    "max_depth": 10,
    "min_samples_split": 2,
    "random_state": 42,
    "class_weight": "balanced"
}

print(f"\n=== Model Configuration ===")
for param, value in hyperparameters.items():
    print(f"  {param}: {value}")

# Using dictionary to map categories to numeric codes
