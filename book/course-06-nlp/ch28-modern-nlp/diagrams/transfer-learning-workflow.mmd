    style FTData fill:#FCE4EC,stroke:#E91E63
    style AddHead fill:#F3E5F5,stroke:#9C27B0
    style FineTune fill:#9C27B0,stroke:#7B1FA2,color:#fff
    style FTModel fill:#F3E5F5,stroke:#9C27B0
    style Deploy fill:#4CAF50,stroke:#388E3C,color:#fff
    style End fill:#E8F5E9,stroke:#4CAF50

