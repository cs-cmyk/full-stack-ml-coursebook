# 9. Self-Supervised Learning Benefits
ax9 = plt.subplot(3, 3, 9)

# Training paradigms
paradigms = ['Supervised\n(1M labeled)', 'Self-Supervised\n(100M unlabeled)',
             'Combined\n(SSL + finetune)']
